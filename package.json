{
  "name": "unit-talk-core",
  "version": "1.0.0",
  "description": "Clean monorepo with npm workspaces, TypeScript, and comprehensive tooling",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "migrate:up": "npm run migrate:up --workspace=packages/db",
    "migrate:down": "npm run migrate:down --workspace=packages/db",
    "migrate:dry-run": "npm run migrate:dry-run --workspace=packages/db",
    "accept:all": "npm run accept:all --workspace=scripts/e2e",
    "accept:env": "npm run accept:env --workspace=scripts/e2e",
    "accept:psql": "npm run accept:psql --workspace=scripts/e2e",
    "accept:migration": "npm run accept:migration --workspace=scripts/e2e",
    "accept:metrics": "npm run accept:metrics --workspace=scripts/e2e",
    "accept:security": "npm run accept:security --workspace=scripts/e2e",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}