{
  "name": "unit-talk-core",
  "version": "1.0.0",
  "description": "Clean monorepo with npm workspaces, TypeScript, and comprehensive tooling",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "migrate:up": "npm run migrate:up --workspace=packages/db",
    "migrate:down": "npm run migrate:down --workspace=packages/db",
    "migrate:dry-run": "npm run migrate:dry-run --workspace=packages/db",
    "accept:all": "npm run accept:all --workspace=scripts/e2e",
    "accept:env": "npm run accept:env --workspace=scripts/e2e",
    "accept:psql": "npm run accept:psql --workspace=scripts/e2e",
    "accept:migration": "npm run accept:migration --workspace=scripts/e2e",
    "accept:metrics": "npm run accept:metrics --workspace=scripts/e2e",
    "accept:security": "npm run accept:security --workspace=scripts/e2e",
    "db:seed:canary": "tsx scripts/db/seed-canary.ts",
    "db:cleanup:canary": "tsx scripts/db/cleanup-canary.ts",
    "e2e:shadow": "tsx scripts/e2e/src/shadow-run.ts",
    "test:logic:unit": "npm run test --workspace=packages/logic",
    "test:pipeline:e2e": "npm run e2e:shadow",
    "claude:pre": "cross-env CLAUDE_FLOW_CMD=\"%*\" tsx scripts/claude/hooks.ts pre",
    "claude:post": "cross-env CLAUDE_FLOW_CMD=\"%*\" tsx scripts/claude/hooks.ts post",
    "canary:monitor": "tsx scripts/canary/monitor.ts",
    "env:validate": "tsx scripts/env/validate.ts",
    "smoke:discord": "tsx scripts/smoke/discord.ts",
    "smoke:db": "tsx scripts/smoke/db.ts",
    "smoke:temporal": "tsx scripts/smoke/temporal.ts",
    "smoke:temporal:live": "tsx scripts/smoke/temporal-live.ts",
    "smoke:supabase": "tsx scripts/smoke/supabase.ts",
    "smoke:supabase:live": "tsx scripts/smoke/supabase-live.ts",
    "smoke:all": "node -e \"(async()=>{const {spawnSync}=require('child_process');const run=c=>spawnSync(c,{shell:true,stdio:'inherit'});['npm run env:validate','npm run smoke:db','npm run smoke:temporal','npm run smoke:supabase','npm run smoke:discord'].forEach(x=>run(x));})();\"",
    "ops:parity": "tsx scripts/ops/parity-check.ts",
    "ops:rls": "tsx scripts/ops/rls-watch.ts",
    "ops:temporal": "tsx scripts/ops/temporal-health.ts",
    "ops:all": "tsx scripts/ops/ops-all.ts",
    "contracts:static": "tsx scripts/contracts/static-guards.ts",
    "contracts:runtime": "tsx scripts/contracts/runtime-tests.ts",
    "contracts:all": "node -e \"(s=>s.split(';').forEach(c=>require('child_process').execSync(c,{stdio:'inherit'})))('npm run contracts:static; npm run contracts:runtime')\"",
    "db:migrate:dry": "tsx scripts/db/migrate-dry.ts",
    "db:migrate:up": "tsx scripts/db/migrate-up.ts",
    "db:index:audit": "tsx scripts/db/index-audit.ts",
    "acceptance:db-hygiene": "tsx scripts/acceptance/db-hygiene.ts",
    "db:verify:shape": "tsx scripts/db/verify-shape.ts",
    "db:verify:session": "tsx scripts/db/verify-session.ts",
    "db:patch:shape": "tsx scripts/db/shape-patch-direct.ts",
    "db:check:columns": "tsx scripts/db/column-check.ts",
    "db:shape-patch": "tsx scripts/db/shape-patch-direct.ts",
    "db:column-check": "tsx scripts/db/column-check.ts",
    "ops:accept": "node scripts/ops/acceptance-runner.js",
    "ops:dashboard": "node scripts/ops/emit-dashboard.js",
    "ops:phase:a": "cross-env SHADOW_MODE=true PUBLISH_TO_DISCORD=false ALLOW_PROMOTION_IN_SHADOW=false npm-run-all db:shape-patch db:column-check ops:accept ops:dashboard",
    "ops:phase:b": "cross-env SHADOW_MODE=false PUBLISH_TO_DISCORD=false npm-run-all db:shape-patch db:column-check ops:accept ops:dashboard",
    "ops:phase:c": "cross-env SHADOW_MODE=false PUBLISH_TO_DISCORD=false npm-run-all ops:accept ops:dashboard",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@temporalio/client": "^1.12.3",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.1",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
