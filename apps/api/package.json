{
  "name": "@unit-talk/api",
  "version": "1.0.0",
  "description": "Express API server with health and metrics endpoints",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
