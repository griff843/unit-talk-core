  "dependencies": {
    "@unit-talk/config": "*",
    "@unit-talk/observability": "*",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21"
  }
}