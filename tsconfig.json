{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@unit-talk/config": [
        "./packages/config/src"
      ],
      "@unit-talk/db": [
        "./packages/db/src"
      ],
      "@unit-talk/shared": [
        "./packages/shared/src"
      ],
      "@unit-talk/observability": [
        "./packages/observability/src"
      ],
      "@unit-talk/logic": [
        "./packages/logic/src"
      ],
      "@unit-talk/logic/*": [
        "./packages/logic/src/*"
      ]
    }
  },
  "include": [
    "apps/**/*",
    "packages/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}