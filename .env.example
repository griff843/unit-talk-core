# Example environment file for local development
# Do NOT commit real secrets. Use GitHub Environments for CI/CD.

# Core configuration (see RUNBOOK.md)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
API_PORT=3000
NODE_ENV=staging
SHADOW_MODE=true
PUBLISH_TO_DISCORD=false

# Linear integration (used in CI via GitHub Environments)
# Leave empty locally; set in GitHub -> Environments -> staging/production
LINEAR_API_KEY=
LINEAR_TEAM_ID=

