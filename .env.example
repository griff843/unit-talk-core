# =============================================================================
# UNIT TALK CORE - Environment Configuration Template
# =============================================================================
# SECURITY: Do NOT commit real secrets. Use GitHub Environments for CI/CD.
# This file documents all required environment variables for the system.

# =============================================================================
# 🔧 CORE APPLICATION SETTINGS
# =============================================================================

# Node.js environment - affects logging, error handling, and feature flags
# Valid values: development | staging | production
NODE_ENV=development

# API server port - must be available and not conflict with other services
# Valid range: 1024-65535 (avoid 3001-3010 reserved for other services)
API_PORT=3000

# Worker concurrency settings
# WORKER_CONCURRENCY: Max concurrent operations (default: 5)
# WORKER_MAX_RETRIES: Max retry attempts for failed operations (default: 3)
WORKER_CONCURRENCY=5
WORKER_MAX_RETRIES=3

# =============================================================================
# 🗄️ DATABASE & STORAGE CONFIGURATION
# =============================================================================

# Primary database connection string
# Format: postgresql://user:password@host:port/database
# Required: Must be a valid PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/unit_talk

# Direct database connection for migrations and system operations
# Uses direct connection bypassing connection pooling for schema operations
# Falls back to DATABASE_URL if not provided
DATABASE_URL_DIRECT=postgresql://postgres:password@localhost:5432/unit_talk?sslmode=require

# Supabase configuration (primary data store)
# SUPABASE_URL: Your Supabase project URL (https://xxx.supabase.co)
# SUPABASE_ANON_KEY: Public anon key for client-side operations
# SUPABASE_SERVICE_KEY: Private service key for server-side operations (sensitive)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# Database pool settings
# DB_POOL_MIN: Minimum database connections (default: 2)
# DB_POOL_MAX: Maximum database connections (default: 10)
DB_POOL_MIN=2
DB_POOL_MAX=10

# =============================================================================
# 🚦 FEATURE FLAGS & OPERATIONAL MODES
# =============================================================================

# Shadow mode - when true, operations run without side effects
# CRITICAL: Must be 'true' in CI/E2E tests, 'false' in production
SHADOW_MODE=true

# Discord publishing control
# CRITICAL: Must be 'false' in CI/E2E tests to prevent spam
PUBLISH_TO_DISCORD=false

# Allow promotion in shadow mode (advanced testing)
# When false (default), no promotions are written to DB in shadow mode
# When true, promotions are written but marked with shadow context
ALLOW_PROMOTION_IN_SHADOW=false

# Promotion flood guard - maximum promotions allowed per 5-minute window
# Prevents over-promotion (100s/1000s of picks)
MAX_ALLOWED_PROMOTES_5MIN=20

# Row Level Security (RLS) configuration
# Used by withSession() wrapper for app queries (not migrations)
# APP_ROLE_FOR_TASK: Session role for database operations (default: promoter)  
# APP_TENANT_ID: Tenant identifier for multi-tenancy (default: public)
# RLS_ENABLED: Enable Row Level Security for app queries (default: true)
APP_ROLE_FOR_TASK=promoter
APP_TENANT_ID=public
RLS_ENABLED=true

# Debug and development features
# ENABLE_DEBUG_ROUTES: Expose debug endpoints (never true in production)
# ENABLE_ADMIN_ROUTES: Enable admin-only operations
ENABLE_DEBUG_ROUTES=false
ENABLE_ADMIN_ROUTES=false

# =============================================================================
# ⚡ TEMPORAL WORKFLOW ENGINE
# =============================================================================

# Temporal server connection
# TEMPORAL_SERVER_ADDRESS: Temporal server host:port
# TEMPORAL_TASK_QUEUE: Queue name for this application's workflows
TEMPORAL_SERVER_ADDRESS=localhost:7233
TEMPORAL_TASK_QUEUE=unit-talk-queue

# Temporal namespace and client settings
# TEMPORAL_NAMESPACE: Temporal namespace (default: default)
# TEMPORAL_CLIENT_TIMEOUT: Client operation timeout in seconds
TEMPORAL_NAMESPACE=default
TEMPORAL_CLIENT_TIMEOUT=30

# =============================================================================
# 📊 OBSERVABILITY & MONITORING
# =============================================================================

# Logging configuration
# LOG_LEVEL: Minimum log level to output (debug|info|warn|error)
# LOG_FORMAT: Log output format (json|text)
LOG_LEVEL=info
LOG_FORMAT=json

# OpenTelemetry tracing
# OTEL_ENABLED: Enable distributed tracing
# OTEL_EXPORTER_OTLP_ENDPOINT: OTLP endpoint for trace export
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Health check configuration
# HEALTH_CHECK_TIMEOUT: Health check timeout in seconds
# HEALTH_CHECK_INTERVAL: Interval between health checks in seconds
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# 🔐 EXTERNAL SERVICE INTEGRATIONS
# =============================================================================

# Linear project management (CI/CD integration)
# Used for automated issue reporting and project tracking
# Leave empty locally; set in GitHub Environments -> staging/production
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# Discord bot configuration (for notifications and alerts)
# DISCORD_BOT_TOKEN: Bot token from Discord Developer Portal
# DISCORD_GUILD_ID: Server ID where bot operates
# DISCORD_CHANNEL_PICKS: Channel ID for pick notifications
# DISCORD_CHANNEL_ALERTS: Channel ID for system alerts
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_PICKS=
DISCORD_CHANNEL_ALERTS=

# Sports data providers
# ESPN_API_KEY: ESPN API key for sports data
# ODDS_API_KEY: The Odds API key for betting odds
# PROVIDER_RATE_LIMIT: Requests per minute limit (default: 100)
ESPN_API_KEY=
ODDS_API_KEY=
PROVIDER_RATE_LIMIT=100

# =============================================================================
# 🚨 SECURITY & AUTHENTICATION
# =============================================================================

# JWT configuration for internal service authentication
# JWT_SECRET: Secret key for signing tokens (generate with crypto.randomBytes(64))
# JWT_EXPIRES_IN: Token expiration time (e.g., 1h, 24h, 7d)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=24h

# API rate limiting
# RATE_LIMIT_WINDOW_MS: Time window in milliseconds
# RATE_LIMIT_MAX_REQUESTS: Max requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS configuration
# CORS_ORIGIN: Allowed origins (comma-separated)
# CORS_CREDENTIALS: Allow credentials in CORS requests
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# =============================================================================
# 🏗️ INFRASTRUCTURE & PERFORMANCE
# =============================================================================

# Redis configuration (caching and session storage)
# REDIS_URL: Redis connection string
# REDIS_TTL: Default TTL for cached items in seconds
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# Metrics and monitoring
# METRICS_PORT: Port for Prometheus metrics endpoint (different from API_PORT)
# METRICS_PATH: Path for metrics endpoint
METRICS_PORT=9090
METRICS_PATH=/metrics

# Performance tuning
# MAX_REQUEST_SIZE: Maximum request body size
# REQUEST_TIMEOUT: Request timeout in seconds
# KEEP_ALIVE_TIMEOUT: Keep-alive timeout for HTTP connections
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT=30
KEEP_ALIVE_TIMEOUT=5

# =============================================================================
# 🧪 TESTING & DEVELOPMENT
# =============================================================================

# Test database (separate from main DATABASE_URL)
# TEST_DATABASE_URL: Dedicated database for testing
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/unit_talk_test

# E2E testing configuration
# E2E_TIMEOUT: Test timeout in milliseconds
# E2E_RETRY_ATTEMPTS: Number of retry attempts for flaky tests
E2E_TIMEOUT=30000
E2E_RETRY_ATTEMPTS=2

# Development features
# DEV_ENABLE_PLAYGROUND: Enable GraphQL/API playground
# DEV_MOCK_EXTERNAL_APIS: Mock external API calls for development
DEV_ENABLE_PLAYGROUND=true
DEV_MOCK_EXTERNAL_APIS=false

# =============================================================================
# 📝 USAGE NOTES
# =============================================================================
# 
# 1. SECURITY: Never commit real values to version control
# 2. ENVIRONMENTS: Use GitHub Environments for staging/production secrets
# 3. VALIDATION: All variables are validated at startup (fail-closed)
# 4. DOCUMENTATION: Each variable includes purpose and valid values
# 5. PORTS: Ensure no port conflicts (API=3000, Metrics=9090, etc.)
# 
# For production deployment:
# - Set all _API_KEY and _SECRET variables in GitHub Environments
# - Ensure SHADOW_MODE=false and PUBLISH_TO_DISCORD=true in production
# - Use strong, randomly generated secrets (min 32 characters)
# - Enable OTEL_ENABLED=true for production monitoring
# 
# =============================================================================

